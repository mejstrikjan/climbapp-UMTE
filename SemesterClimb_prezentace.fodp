<?xml version="1.0" encoding="UTF-8"?>
<office:document
  xmlns:office="urn:oasis:names:tc:opendocument:xmlns:office:1.0"
  xmlns:style="urn:oasis:names:tc:opendocument:xmlns:style:1.0"
  xmlns:text="urn:oasis:names:tc:opendocument:xmlns:text:1.0"
  xmlns:draw="urn:oasis:names:tc:opendocument:xmlns:drawing:1.0"
  xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"
  xmlns:svg="urn:oasis:names:tc:opendocument:xmlns:svg-compatible:1.0"
  xmlns:presentation="urn:oasis:names:tc:opendocument:xmlns:presentation:1.0"
  xmlns:dc="http://purl.org/dc/elements/1.1/"
  xmlns:meta="urn:oasis:names:tc:opendocument:xmlns:meta:1.0"
  office:version="1.3"
  office:mimetype="application/vnd.oasis.opendocument.presentation">
  <office:meta>
    <meta:generator>OpenAI Codex</meta:generator>
    <dc:title>Semester Climb – prezentace</dc:title>
  </office:meta>
  <office:settings/>
  <office:scripts/>
  <office:font-face-decls>
    <style:font-face style:name="Liberation Sans" svg:font-family="Liberation Sans"/>
  </office:font-face-decls>
  <office:styles>
    <style:style style:name="dp1" style:family="drawing-page">
      <style:drawing-page-properties presentation:background-visible="true" draw:fill="solid" draw:fill-color="#F4EBDD"/>
    </style:style>
    <style:style style:name="dp2" style:family="drawing-page">
      <style:drawing-page-properties presentation:background-visible="true" draw:fill="solid" draw:fill-color="#1F1A17"/>
    </style:style>
    <style:style style:name="gr1" style:family="graphic">
      <style:graphic-properties draw:fill="none" draw:stroke="none"/>
    </style:style>
    <style:style style:name="TitleDark" style:family="paragraph">
      <style:paragraph-properties fo:text-align="center"/>
      <style:text-properties fo:font-size="30pt" fo:font-weight="bold" style:font-name="Liberation Sans" fo:color="#FFF8F1"/>
    </style:style>
    <style:style style:name="SubDark" style:family="paragraph">
      <style:paragraph-properties fo:text-align="center"/>
      <style:text-properties fo:font-size="16pt" style:font-name="Liberation Sans" fo:color="#E8D8C9"/>
    </style:style>
    <style:style style:name="TitleLight" style:family="paragraph">
      <style:text-properties fo:font-size="24pt" fo:font-weight="bold" style:font-name="Liberation Sans" fo:color="#A94B1C"/>
    </style:style>
    <style:style style:name="BodyLight" style:family="paragraph">
      <style:paragraph-properties fo:margin-bottom="0.16cm"/>
      <style:text-properties fo:font-size="18pt" style:font-name="Liberation Sans" fo:color="#241F1B"/>
    </style:style>
    <style:style style:name="BodyMuted" style:family="paragraph">
      <style:paragraph-properties fo:margin-bottom="0.12cm"/>
      <style:text-properties fo:font-size="14pt" style:font-name="Liberation Sans" fo:color="#6A5F57"/>
    </style:style>
  </office:styles>
  <office:automatic-styles>
    <style:page-layout style:name="PM1">
      <style:page-layout-properties fo:page-width="28cm" fo:page-height="21cm" style:print-orientation="landscape" fo:margin-top="0cm" fo:margin-bottom="0cm" fo:margin-left="0cm" fo:margin-right="0cm"/>
    </style:page-layout>
    <style:style style:name="FrameNone" style:family="graphic">
      <style:graphic-properties draw:fill="none" draw:stroke="none"/>
    </style:style>
    <style:style style:name="PanelMain" style:family="graphic">
      <style:graphic-properties draw:fill="solid" draw:fill-color="#FFF8F1" draw:stroke="solid" svg:stroke-color="#D9682E" draw:stroke-width="0.05cm" draw:corner-radius="0.2cm"/>
    </style:style>
    <style:style style:name="PanelSide" style:family="graphic">
      <style:graphic-properties draw:fill="solid" draw:fill-color="#F7F0E7" draw:stroke="solid" svg:stroke-color="#D7C1AE" draw:stroke-width="0.03cm" draw:corner-radius="0.2cm"/>
    </style:style>
    <style:style style:name="AccentBar" style:family="graphic">
      <style:graphic-properties draw:fill="solid" draw:fill-color="#D9682E" draw:stroke="none" draw:corner-radius="0.2cm"/>
    </style:style>
  </office:automatic-styles>
  <office:master-styles>
    <style:master-page style:name="Standard" style:page-layout-name="PM1" draw:style-name="dp1"/>
    <style:master-page style:name="DarkMaster" style:page-layout-name="PM1" draw:style-name="dp2"/>
  </office:master-styles>
  <office:body>
    <office:presentation>
      <draw:page draw:name="Titul" draw:style-name="dp2" draw:master-page-name="DarkMaster">
        <draw:frame draw:style-name="AccentBar" svg:x="2.4cm" svg:y="3.2cm" svg:width="6.2cm" svg:height="0.55cm">
          <draw:text-box/>
        </draw:frame>
        <draw:frame draw:style-name="FrameNone" draw:text-style-name="gr1" svg:x="2.4cm" svg:y="5.1cm" svg:width="23cm" svg:height="3.5cm">
          <draw:text-box>
            <text:p text:style-name="TitleDark">Semester Climb</text:p>
          </draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="FrameNone" draw:text-style-name="gr1" svg:x="3.2cm" svg:y="9.4cm" svg:width="21.5cm" svg:height="3.2cm">
          <draw:text-box>
            <text:p text:style-name="SubDark">Semestrální projekt z mobilního vývoje</text:p>
            <text:p text:style-name="SubDark">Nativní Android aplikace v Kotlinu pro evidenci lezení</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>

      <draw:page draw:name="Téma projektu" draw:style-name="dp1" draw:master-page-name="Standard">
        <draw:frame draw:style-name="FrameNone" svg:x="1.6cm" svg:y="1.1cm" svg:width="16cm" svg:height="2cm">
          <draw:text-box><text:p text:style-name="TitleLight">Téma projektu</text:p></draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelMain" svg:x="1.6cm" svg:y="3.2cm" svg:width="25cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyLight">Aplikace slouží jako lezecký deník a správce míst pro lezení.</text:p>
            <text:p text:style-name="BodyLight">Uživatel pracuje s oblastmi, skalami, sektory a konkrétními cestami.</text:p>
            <text:p text:style-name="BodyLight">Ke každé cestě lze ukládat výstupy, session, fotky a polohu na mapě.</text:p>
            <text:p text:style-name="BodyLight">Projekt vznikl jako zjednodušená, ale použitelná nativní verze původní aplikace.</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>

      <draw:page draw:name="Technologie" draw:style-name="dp1" draw:master-page-name="Standard">
        <draw:frame draw:style-name="FrameNone" svg:x="1.6cm" svg:y="1.1cm" svg:width="16cm" svg:height="2cm">
          <draw:text-box><text:p text:style-name="TitleLight">Použité technologie</text:p></draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelMain" svg:x="1.6cm" svg:y="3.2cm" svg:width="12.1cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyLight">Kotlin</text:p>
            <text:p text:style-name="BodyLight">Jetpack Compose</text:p>
            <text:p text:style-name="BodyLight">Compose Navigation</text:p>
            <text:p text:style-name="BodyLight">Hilt</text:p>
            <text:p text:style-name="BodyLight">Coroutines</text:p>
          </draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelMain" svg:x="14.5cm" svg:y="3.2cm" svg:width="12.1cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyLight">Room</text:p>
            <text:p text:style-name="BodyLight">DataStore</text:p>
            <text:p text:style-name="BodyLight">Mapy.com REST API</text:p>
            <text:p text:style-name="BodyLight">Android foto workflow</text:p>
            <text:p text:style-name="BodyLight">Lokální persistence bez backendu</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>

      <draw:page draw:name="Architektura" draw:style-name="dp1" draw:master-page-name="Standard">
        <draw:frame draw:style-name="FrameNone" svg:x="1.6cm" svg:y="1.1cm" svg:width="16cm" svg:height="2cm">
          <draw:text-box><text:p text:style-name="TitleLight">Architektura aplikace</text:p></draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelMain" svg:x="1.6cm" svg:y="3.2cm" svg:width="25cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyLight">UI vrstva: Compose obrazovky a komponenty</text:p>
            <text:p text:style-name="BodyLight">ViewModel vrstva: stav obrazovek a obsluha akcí</text:p>
            <text:p text:style-name="BodyLight">Repository vrstva: Room, DataStore a práce se soubory mimo UI thread</text:p>
            <text:p text:style-name="BodyLight">Datová vrstva: entity pro oblasti, skály, sektory, cesty, výstupy a session</text:p>
            <text:p text:style-name="BodyLight">Dependency injection: Hilt moduly a centrální konfigurace</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>

      <draw:page draw:name="Funkce" draw:style-name="dp1" draw:master-page-name="Standard">
        <draw:frame draw:style-name="FrameNone" svg:x="1.6cm" svg:y="1.1cm" svg:width="16cm" svg:height="2cm">
          <draw:text-box><text:p text:style-name="TitleLight">Hlavní funkcionalita</text:p></draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelMain" svg:x="1.6cm" svg:y="3.2cm" svg:width="16.4cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyLight">Správa oblastí včetně typu: sport, boulder, trad, indoor</text:p>
            <text:p text:style-name="BodyLight">Hierarchie oblast → skála → sektor při vytváření cesty</text:p>
            <text:p text:style-name="BodyLight">Záznam výstupů včetně data, stylu, poznámek a session</text:p>
            <text:p text:style-name="BodyLight">Mapa s markery a výběrem souřadnic klepnutím do mapy</text:p>
            <text:p text:style-name="BodyLight">Fotka cesty přímo ve formuláři</text:p>
          </draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelSide" svg:x="18.7cm" svg:y="3.2cm" svg:width="7.9cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyMuted">Aplikace je navržená tak, aby šla použít i bez internetu.</text:p>
            <text:p text:style-name="BodyMuted">Data se ukládají lokálně do zařízení.</text:p>
            <text:p text:style-name="BodyMuted">Uživatelské rozhraní bylo průběžně upraveno pro pohodlnější práci.</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>

      <draw:page draw:name="Zadání" draw:style-name="dp1" draw:master-page-name="Standard">
        <draw:frame draw:style-name="FrameNone" svg:x="1.6cm" svg:y="1.1cm" svg:width="16cm" svg:height="2cm">
          <draw:text-box><text:p text:style-name="TitleLight">Splnění zadání</text:p></draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelMain" svg:x="1.6cm" svg:y="3.2cm" svg:width="25cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyLight">Alespoň 5 obrazovek: splněno</text:p>
            <text:p text:style-name="BodyLight">Blocking I/O mimo UI thread: splněno přes repository a coroutines</text:p>
            <text:p text:style-name="BodyLight">Datová persistence: splněno pomocí Room a DataStore</text:p>
            <text:p text:style-name="BodyLight">Dependency injection: splněno pomocí Hilt</text:p>
            <text:p text:style-name="BodyLight">Vhodné uspořádání projektu: data / di / navigation / ui / viewmodel</text:p>
            <text:p text:style-name="BodyLight">Něco navíc: mapa a foto workflow</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>

      <draw:page draw:name="Ukázka práce" draw:style-name="dp1" draw:master-page-name="Standard">
        <draw:frame draw:style-name="FrameNone" svg:x="1.6cm" svg:y="1.1cm" svg:width="16cm" svg:height="2cm">
          <draw:text-box><text:p text:style-name="TitleLight">Ukázka práce v aplikaci</text:p></draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="PanelMain" svg:x="1.6cm" svg:y="3.2cm" svg:width="25cm" svg:height="14.9cm">
          <draw:text-box>
            <text:p text:style-name="BodyLight">1. Uživatel založí oblast a kliknutím do mapy nastaví polohu</text:p>
            <text:p text:style-name="BodyLight">2. Přidá cestu a zařadí ji do oblasti, skály a sektoru</text:p>
            <text:p text:style-name="BodyLight">3. Ve formuláři cesty pořídí fotku linie</text:p>
            <text:p text:style-name="BodyLight">4. V deníku založí session a zapisuje jednotlivé výstupy</text:p>
            <text:p text:style-name="BodyLight">5. V mapě a profilu vidí přehled uložených dat</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>

      <draw:page draw:name="Závěr" draw:style-name="dp2" draw:master-page-name="DarkMaster">
        <draw:frame draw:style-name="AccentBar" svg:x="9.1cm" svg:y="4.6cm" svg:width="9.8cm" svg:height="0.55cm">
          <draw:text-box/>
        </draw:frame>
        <draw:frame draw:style-name="FrameNone" svg:x="3cm" svg:y="7cm" svg:width="22cm" svg:height="3cm">
          <draw:text-box>
            <text:p text:style-name="TitleDark">Děkuji za pozornost</text:p>
          </draw:text-box>
        </draw:frame>
        <draw:frame draw:style-name="FrameNone" svg:x="5cm" svg:y="11cm" svg:width="18cm" svg:height="3cm">
          <draw:text-box>
            <text:p text:style-name="SubDark">Dotazy?</text:p>
          </draw:text-box>
        </draw:frame>
      </draw:page>
    </office:presentation>
  </office:body>
</office:document>
